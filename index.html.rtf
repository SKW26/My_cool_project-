\}\
\
// \uc0\u9472 \u9472  Generate questions via Claude API \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
async function generateQuestions() \{\
  const systemPrompt = `You are a CompTIA A+ exam question writer for Core 1 (220-1101). \
Return ONLY valid JSON \'97 no markdown, no extra text, no code fences.`;\
\
  const userPrompt = `Generate exactly 15 unique multiple-choice practice questions for CompTIA A+ Core 1 (220-1101).\
\
Cover these domains:\
- Mobile Devices (2 questions)\
- Networking (4 questions)\
- Hardware (5 questions)\
- Virtualization and Cloud Computing (2 questions)\
- Hardware and Network Troubleshooting (2 questions)\
\
Rules:\
- Each question has exactly 4 options labeled A, B, C, D\
- Only one correct answer (0-indexed: 0=A, 1=B, 2=C, 3=D)\
- Vary difficulty: mix easy, medium, hard\
- Cover diverse subtopics: cables, RAM types, storage interfaces, CPUs, PSU, RAID, cooling, printers, wireless, TCP/IP, ports, cloud models, virtualization, troubleshooting methodology\
- Explanations must be 3-5 sentences and mention the specific physical device or component name where applicable\
- NEVER repeat questions from previous sessions\
\
Return this exact JSON structure:\
\{\
  "questions": [\
    \{\
      "domain": "HARDWARE",\
      "question": "Question text here?",\
      "options": ["Option A text", "Option B text", "Option C text", "Option D text"],\
      "answer": 0,\
      "explanation": "Detailed explanation here mentioning the specific component or device name."\
    \}\
  ]\
\}`;\
\
  const response = await fetch('https://api.anthropic.com/v1/messages', \{\
    method: 'POST',\
    headers: \{ 'Content-Type': 'application/json' \},\
    body: JSON.stringify(\{\
      model: 'claude-sonnet-4-20250514',\
      max_tokens: 4000,\
      system: systemPrompt,\
      messages: [\{ role: 'user', content: userPrompt \}]\
    \})\
  \});\
\
  if (!response.ok) throw new Error(`API error: $\{response.status\}`);\
  const data = await response.json();\
  const raw  = data.content.filter(b => b.type === 'text').map(b => b.text).join('');\
  const clean = raw.replace(/```json|```/gi, '').trim();\
  const parsed = JSON.parse(clean);\
  return parsed.questions;\
\}\
\
// \uc0\u9472 \u9472  Start quiz \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
async function startQuiz() \{\
  questions = []; answered = 0; correct = 0; pdfBlob = null;\
  document.getElementById('quiz').innerHTML = '';\
  document.getElementById('navScore').style.display = 'none';\
  document.getElementById('progFill').style.width = '0%';\
  document.getElementById('progLabel').textContent = '0 / 15';\
  document.getElementById('pdfStatus').textContent = '';\
  document.getElementById('dlBtn').disabled = false;\
\
  hideAll();\
  show('loading', 'flex');\
\
  try \{\
    questions = await generateQuestions();\
    if (!questions || questions.length < 5) throw new Error('Not enough questions returned');\
    hideAll();\
    show('progressWrap');\
    show('quiz');\
    document.getElementById('navScore').style.display = 'block';\
    renderQuiz();\
  \} catch(err) \{\
    hideAll();\
    show('errorMsg', 'flex');\
    document.getElementById('errorText').textContent = err.message || 'Generation failed. Please try again.';\
  \}\
\}\
\
// \uc0\u9472 \u9472  Render all question cards \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
function renderQuiz() \{\
  const container = document.getElementById('quiz');\
  container.innerHTML = '';\
\
  questions.forEach((q, i) => \{\
    const card = document.createElement('div');\
    card.className = 'question-card';\
    card.id = `card-$\{i\}`;\
\
    const opts = q.options.map((o, j) => `\
      <button class="opt-btn" onclick="pick($\{i\},$\{j\})" id="opt-$\{i\}-$\{j\}">\
        <span class="opt-letter">$\{LETTERS[j]\}.</span>\
        <span class="opt-text">$\{o\}</span>\
      </button>`).join('');\
\
    card.innerHTML = `\
      <div class="q-head">\
        <span class="q-num">Q$\{String(i+1).padStart(2,'0')\}</span>\
        <span class="q-domain">$\{q.domain\}</span>\
        <span class="q-icon" id="icon-$\{i\}"></span>\
      </div>\
      <div class="q-body">\
        <div class="q-text">$\{q.question\}</div>\
        <div class="options">$\{opts\}</div>\
        <div class="explanation" id="exp-$\{i\}">\
          <span class="exp-label">EXPLANATION</span>\
          <div class="exp-text" id="exptext-$\{i\}">$\{q.explanation\}</div>\
          <div class="device-img-wrap" id="imgs-$\{i\}"></div>\
        </div>\
      </div>`;\
    container.appendChild(card);\
  \});\
\}\
\
// \uc0\u9472 \u9472  Handle answer pick \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
async function pick(qi, oi) \{\
  const card = document.getElementById(`card-$\{qi\}`);\
  if (card.dataset.answered) return;\
  card.dataset.answered = '1';\
\
  const q = questions[qi];\
  const isCorrect = oi === q.answer;\
  if (isCorrect) correct++;\
  answered++;\
\
  // Style options\
  q.options.forEach((_, j) => \{\
    const btn = document.getElementById(`opt-$\{qi\}-$\{j\}`);\
    btn.disabled = true;\
    if (j === q.answer && j === oi) btn.classList.add('sel-correct');\
    else if (j === oi && !isCorrect)  btn.classList.add('sel-wrong');\
    else if (j === q.answer)          btn.classList.add('reveal');\
  \});\
\
  card.classList.add(isCorrect ? 'correct' : 'wrong');\
  const icon = document.getElementById(`icon-$\{qi\}`);\
  icon.textContent = isCorrect ? '\uc0\u10003 ' : '\u10007 ';\
\
  // Show explanation\
  const expEl = document.getElementById(`exp-$\{qi\}`);\
  expEl.classList.add('show');\
\
  // Update nav score\
  document.getElementById('navScoreVal').textContent = `$\{correct\}/$\{answered\}`;\
\
  // Update progress\
  updateProgress();\
\
  // Load device images in explanation\
  loadDeviceImages(qi, q.explanation);\
\
  // Check if done\
  if (answered === questions.length) \{\
    setTimeout(showResults, 600);\
  \}\
\}\
\
// \uc0\u9472 \u9472  Load device images \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
async function loadDeviceImages(qi, explanation) \{\
  const devices = detectDevices(explanation);\
  if (!devices.length) return;\
\
  const wrap = document.getElementById(`imgs-$\{qi\}`);\
\
  for (const dev of devices) \{\
    const imgCard = document.createElement('div');\
    imgCard.className = 'device-img-card';\
    imgCard.innerHTML = `<div class="img-loading">loading image\'85</div>`;\
    wrap.appendChild(imgCard);\
\
    try \{\
      const url = await fetchDeviceImage(dev.query);\
      imgCard.innerHTML = `\
        <img src="$\{url\}" alt="$\{dev.label\}"\
             onerror="this.parentElement.style.display='none'"\
             loading="lazy">\
        <div class="device-img-caption">$\{dev.label.toUpperCase()\}</div>`;\
    \} catch(e) \{\
      imgCard.style.display = 'none';\
    \}\
  \}\
\}\
\
// \uc0\u9472 \u9472  Progress bar \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
function updateProgress() \{\
  const pct = Math.round((answered / questions.length) * 100);\
  document.getElementById('progFill').style.width   = pct + '%';\
  document.getElementById('progLabel').textContent  = `$\{answered\} / $\{questions.length\}`;\
\}\
\
// \uc0\u9472 \u9472  Show results \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
function showResults() \{\
  const pct = Math.round((correct / questions.length) * 100);\
  hideAll();\
  show('results');\
\
  document.getElementById('resScore').textContent = pct + '%';\
  setTimeout(() => \{ document.getElementById('resBar').style.width = pct + '%'; \}, 100);\
\
  const verdict = document.getElementById('resVerdict');\
  if (pct >= 70) \{\
    verdict.textContent = '\uc0\u10003  PASS \'97 Well done!';\
    verdict.className   = 'results-verdict pass';\
  \} else \{\
    verdict.textContent = '\uc0\u10007  NOT PASSING \'97 Keep studying';\
    verdict.className   = 'results-verdict fail';\
  \}\
  document.getElementById('resDetail').textContent =\
    `$\{correct\} correct out of $\{questions.length\} questions. Passing score is 70% ($\{Math.ceil(questions.length*0.7)\}/$\{questions.length\}).`;\
\
  // Domain breakdown\
  buildBreakdown();\
\
  // Auto-build PDF\
  document.getElementById('pdfStatus').textContent = '\uc0\u9203  Building PDF summary\'85';\
  setTimeout(() => \{\
    buildPDF(pct);\
    document.getElementById('pdfStatus').textContent = '\uc0\u10003  PDF ready \'97 click Download PDF Summary';\
  \}, 800);\
\}\
\
// \uc0\u9472 \u9472  Domain breakdown \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
function buildBreakdown() \{\
  const domainMap = \{\};\
  questions.forEach((q, i) => \{\
    const d = q.domain;\
    if (!domainMap[d]) domainMap[d] = \{ total: 0, correct: 0 \};\
    domainMap[d].total++;\
    const card = document.getElementById(`card-$\{i\}`);\
    if (card && card.classList.contains('correct')) domainMap[d].correct++;\
  \});\
\
  const grid = document.getElementById('breakdown');\
  grid.innerHTML = '';\
  for (const [domain, stats] of Object.entries(domainMap)) \{\
    const pct = Math.round((stats.correct / stats.total) * 100);\
    const item = document.createElement('div');\
    item.className = 'bd-item';\
    item.innerHTML = `\
      <div class="bd-domain">$\{domain\}</div>\
      <div class="bd-score">$\{stats.correct\}/$\{stats.total\}</div>\
      <div class="bd-bar"><div class="bd-bar-fill" style="width:$\{pct\}%"></div></div>`;\
    grid.appendChild(item);\
  \}\
\}\
\
// \uc0\u9472 \u9472  Build PDF \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
function buildPDF(scorePct) \{\
  const \{ jsPDF \} = window.jspdf;\
  const doc = new jsPDF(\{ orientation: 'portrait', unit: 'mm', format: 'a4' \});\
  const W = 210, margin = 18, contentW = W - margin * 2;\
  let y = 0;\
\
  const addPage = () => \{ doc.addPage(); y = 20; \};\
  const checkY = (need) => \{ if (y + need > 275) addPage(); \};\
\
  const txt = (text, x, yy, opts=\{\}) => \{\
    doc.setFontSize(opts.size||10);\
    doc.setFont('helvetica', opts.style||'normal');\
    doc.setTextColor(...(opts.color||[30,30,50]));\
    const lines = doc.splitTextToSize(String(text), opts.maxW || contentW);\
    doc.text(lines, x, yy);\
    return lines.length * ((opts.size||10) * 0.4 + 1.2);\
  \};\
\
  // \uc0\u9472 \u9472  Cover \u9472 \u9472 \
  doc.setFillColor(7, 9, 15);\
  doc.rect(0, 0, W, 297, 'F');\
  // accent bar\
  doc.setFillColor(79, 142, 247);\
  doc.rect(0, 0, W, 3, 'F');\
\
  y = 60;\
  doc.setFontSize(38); doc.setFont('helvetica','bold');\
  doc.setTextColor(255,255,255);\
  doc.text('CompTIA A+', W/2, y, \{ align: 'center' \});\
  y += 16;\
  doc.setFontSize(20); doc.setTextColor(79,142,247);\
  doc.text('Core 1 (220-1101)', W/2, y, \{ align: 'center' \});\
  y += 10;\
  doc.setFontSize(13); doc.setTextColor(180,200,220);\
  doc.text('Practice Exam \'97 Full Answer Explanations', W/2, y, \{ align: 'center' \});\
\
  y += 24;\
  // info box\
  doc.setFillColor(20, 28, 48);\
  doc.roundedRect(margin, y, contentW, 40, 3, 3, 'F');\
  doc.setFontSize(10); doc.setFont('helvetica','normal'); doc.setTextColor(150,170,200);\
  const infoLines = [\
    `Score: $\{scorePct\}%  ($\{correct\} / $\{questions.length\} correct)`,\
    `Status: $\{scorePct >= 70 ? 'PASS \uc0\u10003 ' : 'NOT PASSING \u10007 '\}  |  Passing threshold: 70%`,\
    `Questions: $\{questions.length\}  |  Domains: Hardware, Networking, Mobile, Cloud, Troubleshooting`,\
    `Generated: $\{new Date().toLocaleDateString('en-US', \{year:'numeric',month:'long',day:'numeric'\})\}`\
  ];\
  infoLines.forEach((line, li) => \{\
    doc.text(line, margin + 8, y + 9 + li * 7);\
  \});\
\
  // \uc0\u9472 \u9472  Questions \u9472 \u9472 \
  doc.addPage();\
  y = 20;\
  // header bar\
  doc.setFillColor(79,142,247);\
  doc.rect(0, 0, W, 2, 'F');\
\
  questions.forEach((q, i) => \{\
    checkY(40);\
\
    // Question number + domain pill\
    doc.setFillColor(20, 28, 48);\
    doc.roundedRect(margin, y, contentW, 8, 2, 2, 'F');\
    doc.setFontSize(8); doc.setFont('helvetica','bold');\
    doc.setTextColor(79,142,247);\
    doc.text(`Q$\{String(i+1).padStart(2,'0')\}`, margin+4, y+5.5);\
    doc.setTextColor(100,120,150);\
    doc.text(q.domain, margin+20, y+5.5);\
\
    // Pass/fail indicator\
    const card = document.getElementById(`card-$\{i\}`);\
    const isC  = card && card.classList.contains('correct');\
    doc.setTextColor(isC ? 52 : 248, isC ? 211 : 113, isC ? 153 : 113);\
    doc.text(isC ? '\uc0\u10003  CORRECT' : '\u10007  WRONG', W - margin - 4, y+5.5, \{align:'right'\});\
    y += 12;\
\
    // Question text\
    doc.setFontSize(10); doc.setFont('helvetica','bold'); doc.setTextColor(230,235,245);\
    const qLines = doc.splitTextToSize(q.question, contentW);\
    checkY(qLines.length * 5 + 4);\
    doc.text(qLines, margin, y);\
    y += qLines.length * 5 + 5;\
\
    // Options\
    q.options.forEach((opt, oi) => \{\
      checkY(8);\
      const isCorrectOpt = oi === q.answer;\
      if (isCorrectOpt) \{\
        doc.setFillColor(20, 60, 40);\
        doc.roundedRect(margin, y-4, contentW, 7, 1.5, 1.5, 'F');\
        doc.setDrawColor(52,211,153); doc.setLineWidth(0.3);\
        doc.roundedRect(margin, y-4, contentW, 7, 1.5, 1.5, 'S');\
      \}\
      doc.setFontSize(9);\
      doc.setFont('helvetica', isCorrectOpt ? 'bold' : 'normal');\
      doc.setTextColor(isCorrectOpt ? 52 : 150, isCorrectOpt ? 211 : 165, isCorrectOpt ? 153 : 185);\
      doc.text(`$\{LETTERS[oi]\}.`, margin+3, y+0.5);\
      doc.setTextColor(isCorrectOpt ? 200 : 160, isCorrectOpt ? 240 : 175, isCorrectOpt ? 210 : 195);\
      const oLines = doc.splitTextToSize(opt, contentW - 14);\
      doc.text(oLines, margin+10, y+0.5);\
      y += oLines.length * 4.5 + 2;\
    \});\
\
    y += 3;\
    checkY(25);\
\
    // Explanation box\
    doc.setFillColor(12, 22, 40);\
    const expLines = doc.splitTextToSize(q.explanation, contentW - 12);\
    const expH = expLines.length * 4.5 + 10;\
    checkY(expH + 4);\
    doc.roundedRect(margin, y, contentW, expH, 2, 2, 'F');\
    doc.setFillColor(79,142,247);\
    doc.roundedRect(margin, y, 2.5, expH, 1, 1, 'F');\
    doc.setFontSize(7); doc.setFont('helvetica','bold'); doc.setTextColor(79,142,247);\
    doc.text('EXPLANATION', margin+6, y+5);\
    doc.setFontSize(9); doc.setFont('helvetica','normal'); doc.setTextColor(140,170,200);\
    doc.text(expLines, margin+6, y+10);\
    y += expH + 14;\
  \});\
\
  // \uc0\u9472 \u9472  Summary page \u9472 \u9472 \
  doc.addPage();\
  y = 20;\
  doc.setFillColor(79,142,247); doc.rect(0,0,W,2,'F');\
  doc.setFontSize(18); doc.setFont('helvetica','bold'); doc.setTextColor(230,235,245);\
  doc.text('Performance Summary', margin, y); y += 14;\
\
  // Domain table\
  const domainMap = \{\};\
  questions.forEach((q, i) => \{\
    if (!domainMap[q.domain]) domainMap[q.domain] = \{ total:0, correct:0 \};\
    domainMap[q.domain].total++;\
    const card = document.getElementById(`card-$\{i\}`);\
    if (card && card.classList.contains('correct')) domainMap[q.domain].correct++;\
  \});\
\
  doc.setFontSize(9); doc.setFont('helvetica','bold');\
  doc.setTextColor(79,142,247);\
  doc.text('DOMAIN', margin, y);\
  doc.text('SCORE', margin+90, y);\
  doc.text('RESULT', margin+120, y);\
  y += 5;\
  doc.setDrawColor(30,40,64); doc.setLineWidth(0.4);\
  doc.line(margin, y, W-margin, y); y += 5;\
\
  for (const [domain, stats] of Object.entries(domainMap)) \{\
    checkY(10);\
    const pct = Math.round((stats.correct/stats.total)*100);\
    doc.setFont('helvetica','normal'); doc.setTextColor(200,210,230);\
    doc.text(domain, margin, y);\
    doc.text(`$\{stats.correct\}/$\{stats.total\} ($\{pct\}%)`, margin+90, y);\
    const pass = pct >= 70;\
    doc.setTextColor(pass?52:248, pass?211:113, pass?153:113);\
    doc.text(pass ? 'PASS' : 'REVIEW', margin+120, y);\
    y += 7;\
  \}\
\
  y += 8;\
  doc.setFillColor(20,28,48);\
  doc.roundedRect(margin, y, contentW, 20, 3, 3, 'F');\
  doc.setFontSize(14); doc.setFont('helvetica','bold');\
  doc.setTextColor(scorePct>=70?52:248, scorePct>=70?211:113, scorePct>=70?153:113);\
  doc.text(`Overall: $\{scorePct\}% \'97 $\{scorePct>=70?'PASS \uc0\u10003 ':'NEEDS MORE STUDY \u10007 '\}`, W/2, y+13, \{align:'center'\});\
\
  pdfBlob = doc.output('blob');\
  return doc;\
\}\
\
// \uc0\u9472 \u9472  Download PDF \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
function downloadPDF() \{\
  if (!pdfBlob) \{\
    document.getElementById('pdfStatus').textContent = '\uc0\u9203  Please wait, building PDF\'85';\
    return;\
  \}\
  const url = URL.createObjectURL(pdfBlob);\
  const a   = document.createElement('a');\
  a.href    = url;\
  a.download= `CompTIA_A+_Core1_Practice_$\{new Date().toISOString().slice(0,10)\}.pdf`;\
  a.click();\
  URL.revokeObjectURL(url);\
\}\
</script>\
\
